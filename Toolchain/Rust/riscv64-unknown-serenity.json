{
    "arch": "riscv64",
    "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n32:64-S128",
    "dynamic-linking": true,
    "has-rpath": true,
    "has-thread-local": true,
    "linker-flavor": "gnu-cc",
    "llvm-target": "riscv64-unknown-serenity",
    "max-atomic-width": 64,
    "os": "serenity",
    "position-independent-executables": true,
    "post-link-args": {
        "gnu-cc": [
            "-lc",
            "-lm",
            "-lpthread"
        ]
    },
    "relro-level": "full",
    "stack-probes": {
        "kind": "none"
    },
    "target-family": [
        "unix"
    ],
    "target-pointer-width": 64
}
